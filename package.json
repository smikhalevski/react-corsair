{
  "name": "react-corsair",
  "version": "0.0.11",
  "description": "Because routes are better then URLs.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./history": "./history/index.js",
    "./ssr": "./ssr/index.js",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.build.json && cp package.json README.md LICENSE.txt lib/ && cd lib && npm pkg delete scripts devDependencies",
    "clean": "rimraf lib docs coverage",
    "test": "vitest run",
    "perf": "toofast",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smikhalevski/react-corsair.git"
  },
  "keywords": [
    "url",
    "path",
    "route",
    "router",
    "routing",
    "navigation",
    "location",
    "history",
    "link"
  ],
  "author": "Savva Mikhalevski <smikhalevski@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/smikhalevski/react-corsair/issues"
  },
  "homepage": "https://megastack.dev/react-corsair",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "parallel-universe": "^6.1.2"
  }
}
